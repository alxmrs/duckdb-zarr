# name: test/sql/realistic_queries.test
# description: Realistic end-to-end SQL queries mirroring xarray-sql test patterns
# group: [duckdb_zarr]

require duckdb_zarr

# ── 1. Basic sanity / SELECT ─────────────────────────────────────────────────
# Mirror: test_sanity, test_basic_select_all

# LIMIT is applied before counting.
query I
SELECT COUNT(*) FROM (SELECT lat, lon, air, time FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr') LIMIT 100);
----
100

# Total row count = product of all dimension sizes (2920 × 25 × 53).
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr');
----
3869000

# SELECT * brings back all four columns without error.
query I
SELECT COUNT(*) FROM (SELECT * FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr') LIMIT 10);
----
10

# ── 2. Spatial aggregation (GROUP BY lat, lon) ───────────────────────────────
# Mirror: test_aggregation_small, test_aggregation_large

# Distinct (lat, lon) pairs = 25 × 53 = 1325.
query I
SELECT COUNT(*) FROM (
    SELECT lat, lon, AVG(air) AS air_avg
    FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
    GROUP BY lat, lon
);
----
1325

# Every (lat, lon) pair has exactly the same number of time steps (2920).
query II
SELECT MIN(cnt), MAX(cnt) FROM (
    SELECT lat, lon, COUNT(*) AS cnt
    FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
    GROUP BY lat, lon
);
----
2920	2920

# SUM aggregation: same number of groups.
query I
SELECT COUNT(*) FROM (
    SELECT lat, lon, SUM(air) AS air_total
    FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
    GROUP BY lat, lon
);
----
1325

# Synthetic dataset: 6 lat × 12 lon = 72 spatial groups.
query I
SELECT COUNT(*) FROM (
    SELECT lat, lon, AVG(temperature) AS mean_temp
    FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr')
    GROUP BY lat, lon
);
----
72

# ── 3. Filtering / WHERE ─────────────────────────────────────────────────────
# Mirror: test_weather_queries

# All decoded air values are physically plausible (Kelvin, NCEP reanalysis).
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
WHERE air > 150.0 AND air < 400.0;
----
3869000

# Filter to a single latitude band: 53 lon × 2920 time = 154760 rows.
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
WHERE lat = 15.0;
----
154760

# Integer time coordinate filter (time values 0..7 in float_baseline).
# Rows where time >= 4: 4 time steps × 6 lat × 12 lon = 288.
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr')
WHERE time >= 4;
----
288

# Rows above the mean are roughly half (282 of 576).
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr')
WHERE temperature > (SELECT AVG(temperature) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr'));
----
282

# ── 4. Scalar aggregates ─────────────────────────────────────────────────────
# Mirror: test_synthetic_aggregations

# MIN / MAX are physical bounds for NCEP reanalysis (Kelvin).
query R
SELECT ROUND(MIN(air)::DOUBLE, 1) FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr');
----
221.000000

query R
SELECT ROUND(MAX(air)::DOUBLE, 1) FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr');
----
317.400000

# MIN ≤ AVG ≤ MAX always holds.
query I
SELECT COUNT(*) FROM (
    SELECT MIN(air) AS mn, MAX(air) AS mx, AVG(air) AS av
    FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
) WHERE mn < av AND av < mx;
----
1

# Float baseline: exact MIN and MAX from known seeded random data.
query R
SELECT ROUND(MIN(temperature)::DOUBLE, 3)
FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
-3.899000

query R
SELECT ROUND(MAX(temperature)::DOUBLE, 3)
FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
3.066000

# ── 5. NULL-aware aggregates ─────────────────────────────────────────────────
# Mirror: TestNanAsNull

# sparse.zarr: fill_value=-9999 → NULL. Only the top-left 2×2 chunk is written.
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr');
----
16

# COUNT(col) excludes NULLs; COUNT(*) does not.
query I
SELECT COUNT(data) FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr');
----
4

query I
SELECT COUNT(*) - COUNT(data) AS null_count
FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr');
----
12

# SUM and AVG ignore NULLs; all four real cells = 1.0.
query R
SELECT SUM(data) FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr');
----
4.000000

query R
SELECT AVG(data) FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr');
----
1.000000

# MAX/MIN on a column with NULLs return the non-null extremes.
query R
SELECT MIN(data) FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr');
----
1.000000

query R
SELECT MAX(data) FROM read_zarr('test/fixtures/xarray_tutorial/sparse.zarr');
----
1.000000

# ersstv5: missing_value sentinel → NULL; verify non-null fraction.
query I
SELECT COUNT(sst) FROM read_zarr('test/fixtures/xarray_tutorial/ersstv5.zarr');
----
6856512

# ── 6. Top-N with ORDER BY ───────────────────────────────────────────────────

# Top 10 warmest (lat, lon) pairs by mean air temperature.
query I
SELECT COUNT(*) FROM (
    SELECT lat, lon, AVG(air) AS mean_air
    FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
    GROUP BY lat, lon
    ORDER BY mean_air DESC
    LIMIT 10
);
----
10

# Warmest location is lat=15 °N, lon=257.5 °E (Central America, NCEP).
query RR
SELECT ROUND(lat::DOUBLE, 1), ROUND(lon::DOUBLE, 1)
FROM (
    SELECT lat, lon, AVG(air) AS mean_air
    FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
    GROUP BY lat, lon
    ORDER BY mean_air DESC
    LIMIT 1
);
----
15.000000	257.500000

# ── 7. CTEs and subqueries ───────────────────────────────────────────────────

# Count time steps whose global-mean air temperature exceeds 281 K.
# Exactly half (1460 of 2920) are above that threshold.
query I
WITH time_means AS (
    SELECT time, AVG(air) AS mean_air
    FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
    GROUP BY time
)
SELECT COUNT(*) FROM time_means WHERE mean_air > 281.0;
----
1460

# Count (lat, lon) pairs warmer than the global mean (703 of 1325).
query I
WITH spatial_means AS (
    SELECT lat, lon, AVG(air) AS mean_air
    FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
    GROUP BY lat, lon
)
SELECT COUNT(*) FROM spatial_means
WHERE mean_air > (SELECT AVG(air) FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr'));
----
703

# Subquery: readings above 300 K (tropical/summer). Exact count from NCEP data.
query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
WHERE air > 300.0;
----
191987

# ── 8. Cross-JOIN and multi-store JOIN ───────────────────────────────────────
# Mirror: test_cross_join

# Cross-join distinct lat and lon axes → full spatial grid.
query I
SELECT COUNT(*) FROM
    (SELECT DISTINCT lat FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr')) a
CROSS JOIN
    (SELECT DISTINCT lon FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr')) b;
----
72

