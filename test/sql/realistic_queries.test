# ── 9. Time-axis queries ─────────────────────────────────────────────────────
# Mirror: TestCftimeGregorianLike
# rasm uses a noleap CF calendar; cftime support deferred.
# The five queries below are commented out until cftime is supported.

# query I
# SELECT COUNT(DISTINCT time) FROM read_zarr('test/fixtures/xarray_tutorial/rasm.zarr');
# ----
# 36

# # Total row count = 36 × 205 × 275 = 2029500.
# query I
# SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/rasm.zarr');
# ----
# 2029500

# # COUNT(Tair) excludes NaN-masked ocean/land cells.
# query I
# SELECT COUNT(Tair) FROM read_zarr('test/fixtures/xarray_tutorial/rasm.zarr');
# ----
# 935856

# # Time axis is monotonically increasing when ordered.
# query I
# SELECT COUNT(*) FROM (
#     SELECT time, LAG(time) OVER (ORDER BY time) AS prev_time
#     FROM (SELECT DISTINCT time FROM read_zarr('test/fixtures/xarray_tutorial/rasm.zarr'))
# ) WHERE time <= prev_time;
# ----
# 0

# # Temporal filter: rows in the second half of the time series.
# query I
# SELECT COUNT(DISTINCT time) FROM read_zarr('test/fixtures/xarray_tutorial/rasm.zarr')
# WHERE time > (
#     SELECT (MIN(time) + MAX(time)) / 2.0
#     FROM read_zarr('test/fixtures/xarray_tutorial/rasm.zarr')
# );
# ----
# 18

# ── 10. Window functions ─────────────────────────────────────────────────────

# RANK over spatial groups: top 10 warmest locations via QUALIFY.
query I
SELECT COUNT(*) FROM (
    SELECT lat, lon, AVG(air) AS mean_air
    FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
    GROUP BY lat, lon
    QUALIFY RANK() OVER (ORDER BY AVG(air) DESC) <= 10
);
----
10

# ROW_NUMBER per lat band: each time step within a lat gets a unique number 1..53.
query I
SELECT COUNT(*) FROM (
    SELECT lat, time, air,
           ROW_NUMBER() OVER (PARTITION BY lat, time ORDER BY lon) AS rn
    FROM read_zarr('test/fixtures/xarray_tutorial/air_temperature.zarr')
) WHERE rn = 1;
----
73000

# ── 11. Error cases ──────────────────────────────────────────────────────────
# Mirror: test_invalid_column_name, test_invalid_table_name, test_sql_syntax_error

statement error
SELECT nonexistent FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr');
----
Referenced column "nonexistent" not found

statement error
SELECT * FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline.zarr') WHERE nonexistent > 0;
----
Referenced column "nonexistent" not found

statement error
SELECT * FROM read_zarr('/tmp/duckdb_zarr_nonexistent_path.zarr');
----
