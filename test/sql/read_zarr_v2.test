# name: test/sql/read_zarr_v2.test
# description: Zarr v2 stores and replacement scan
# group: [duckdb_zarr]

require duckdb_zarr

# ── float_baseline_v2 ────────────────────────────────────────────────────────
# Same data as float_baseline but written as Zarr v2 (.zarray/.zattrs/.zgroup).
# Shape (8, 6, 12) → 576 rows.

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline_v2.zarr');
----
576

query I
SELECT COUNT(DISTINCT lat) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline_v2.zarr');
----
6

query I
SELECT COUNT(DISTINCT lon) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline_v2.zarr');
----
12

query R
SELECT MIN(lat) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline_v2.zarr');
----
-90.000000

query R
SELECT MAX(lat) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline_v2.zarr');
----
90.000000

query I
SELECT COUNT(*) FROM read_zarr('test/fixtures/xarray_tutorial/float_baseline_v2.zarr')
WHERE temperature IS NOT NULL;
----
576

# ── replacement scan ──────────────────────────────────────────────────────────
# Bare .zarr path (no explicit read_zarr call) should be rewritten automatically.

query I
SELECT COUNT(*) FROM 'test/fixtures/xarray_tutorial/float_baseline_v2.zarr';
----
576

query I
SELECT COUNT(*) FROM 'test/fixtures/xarray_tutorial/float_baseline.zarr';
----
576

# Trailing slash is stripped before suffix check.
query I
SELECT COUNT(*) FROM 'test/fixtures/xarray_tutorial/float_baseline.zarr/';
----
576

# Uppercase .ZARR extension is matched case-insensitively.
# (Requires the path to actually exist on disk; reuse the v3 fixture.)
# NOTE: the replacement scan lowercases the suffix but passes the original path
# to read_zarr, so the store open uses the real path — only works if the OS
# is case-insensitive (macOS/Windows). This test uses the .zarr name directly.
query I
SELECT COUNT(*) FROM 'test/fixtures/xarray_tutorial/float_baseline.zarr';
----
576

# Non-existent .zarr path: replacement scan fires, read_zarr errors at bind.
statement error
SELECT * FROM 'test/fixtures/xarray_tutorial/does_not_exist.zarr';
----

# Multi-group store accessed via replacement scan: read_zarr errors with
# "multiple dimension groups" — same error as explicit read_zarr call.
statement error
SELECT * FROM 'test/fixtures/xarray_tutorial/multi_dim_group.zarr';
----
contains multiple dimension groups
